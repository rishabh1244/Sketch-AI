      "govern_x": "function govern_x(x) { return x + state.vx * constants.dt; }",

      "govern_y": "function govern_y(y) { state.vy += constants.g * constants.dt; var next_y = y + state.vy * constants.dt; if (next_y + constants.r >= constants.GROUND_Y) { next_y = constants.GROUND_Y - constants.r; state.vy = -state.vy * constants.e; } return next_y; }"
