  "motion": {
    "description": "Piecewise periodic motion of a ball under free fall with perfectly elastic collision",
    "parameters": {
      "g": 9.8,
      "initial_height_units": 100,
      "ball_radius": 10,
      "v0": 0,
      "y0": 0,
      "ground_level_y": 100,
      "time_to_fall": "sqrt(2 * h / g)",
      "time_period": "2 * sqrt(2 * h / g)",
      "T": "2 * sqrt(200 / 9.8) ≈ 9.035 seconds"
    },
    "equations": {
      "free_fall_phase": {
        "formula": "y(t) = y0 + (1/2) * g * t^2",
        "valid_for": "0 <= t <= T/2",
        "note": "Ball falls from rest at height h=0 (screen top ref), reaching ground at t = sqrt(2h/g)"
      },
      "bounce_phase": {
        "formula": "y(t) = ground_level - (1/2) * g * (t - T/2)^2 + v_impact * (t - T/2)",
        "valid_for": "T/2 <= t <= T",
        "note": "After elastic collision, velocity reverses: v_after = -v_before = sqrt(2*g*h)"
      },
      "general_periodic": {
        "formula": "y(t mod T) = h - (1/2)*g*(t mod T - k*T)^2  for integer k",
        "note": "Motion repeats with period T = 2*sqrt(2h/g). No energy loss due to perfect elasticity."
      },
      "velocity": {
        "falling": "v(t) = g * t  (downward, positive)",
        "rising": "v(t) = v_impact - g * (t - T/2)  (upward, negative)",
        "at_impact": "v_impact = sqrt(2 * g * h) ≈ sqrt(2 * 9.8 * 100) ≈ 44.27 units/s"
      },
      "energy_conservation": {
        "kinetic_at_ground": "KE = (1/2) * m * v_impact^2 = m * g * h",
        "potential_at_top": "PE = m * g * h",
        "note": "Total mechanical energy E = m*g*h = constant throughout motion"
      }
    }
  }
